{
  "name": "@agreements-protocol/contracts",
  "version": "1.0.0",
  "description": "Smart contracts for the Agreements Protocol",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "lint": "tsc --noEmit",
    "test": "hardhat test",
    "test:unit": "hardhat test 'test/*.ts'",
    "test:integration": "hardhat test 'test/integration/*.ts'",
    "test:fork": "bash scripts/test-fork.sh",
    "test:gas": "hardhat test --grep 'gas' || true",
    "gas:check": "hardhat test && npx hardhat run scripts/check-gas-thresholds.ts",
    "deploy": "hardhat run scripts/deploy.ts",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:lineaSepolia": "hardhat run scripts/deploy.ts --network lineaSepolia",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:baseSepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "deploy:linea": "hardhat run scripts/deploy.ts --network linea",
    "verify:deployment": "hardhat run scripts/verify-deployment.ts",
    "verify:lineaSepolia": "hardhat run scripts/verify-deployment.ts --network lineaSepolia",
    "verify:sepolia": "hardhat run scripts/verify-deployment.ts --network sepolia",
    "verify:baseSepolia": "hardhat run scripts/verify-deployment.ts --network baseSepolia",
    "verify:base": "hardhat run scripts/verify-deployment.ts --network base",
    "verify:linea": "hardhat run scripts/verify-deployment.ts --network linea",
    "node": "hardhat node",
    "node:fork": "HARDHAT_FORK=true hardhat node",
    "slither": "slither . --config-file slither.config.json",
    "clean": "hardhat clean"
  },
  "keywords": [
    "smart-contracts",
    "hardhat",
    "ethereum"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "chai": "^4.5.0",
    "dotenv": "^16.3.1",
    "hardhat": "^2.19.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
