# Linea Sepolia RPC URL
# Used for forking the network and deploying to Linea Sepolia
# Default: https://rpc.sepolia.linea.build
LINEA_SEPOLIA_RPC_URL=https://rpc.sepolia.linea.build

# Linea mainnet RPC URL
# Default: https://rpc.linea.build
LINEA_RPC_URL=https://rpc.linea.build

# Private key for deploying contracts
# Only needed for public-network deployments (not needed for localhost)
# Format: 0x...
# PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Distinct delegate key for the real MetaMask -> ERC-8004 public trace.
# It may start unfunded; the trace script funds it from PRIVATE_KEY when needed.
# DELEGATE_PRIVATE_KEY=0x...

# Optional Linea Sepolia ERC-4337 bundler endpoint. When set, the Agent Wallet
# trace submits and verifies a real delegated-authority disable user operation.
# Keep credential-bearing endpoint values in local environment files only.
# BUNDLER_RPC_URL=https://linea-sepolia-bundler.example

# Agent Wallet mode uses its own supported Node runtime and CLI entry point.
# The npm trace script sets DELEGATE_MODE=agent-wallet automatically.
# AGENT_WALLET_NODE_BIN=/absolute/path/to/node
# AGENT_WALLET_CLI_BIN=/absolute/path/to/mm

# Optional address fallback for Agent Wallet mode.
# AGENT_WALLET_ADDRESS=0x...

# Optional agent registration URI used by the real ERC-8004 trace.
# ERC8004_AGENT_URI=https://example.com/.well-known/agent-registration.json

# Single Etherscan API key used for verification on both Linea explorers
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Optional explicit override. Public deployments auto-verify when
# ETHERSCAN_API_KEY is set, so most users can leave these commented out.
# VERIFY_CONTRACTS=true
# VERIFY_CONTRACTS=false
# SKIP_CONTRACT_VERIFICATION=true
