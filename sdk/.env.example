# RPC URL for connecting to the blockchain
# Default: http://localhost:8545 (local Hardhat node)
RPC_URL=http://localhost:8545

# Private key for signing transactions
# Default: Hardhat account #0 (0xac0974...)
# Format: 0x...
# PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Agreement Engine contract address
# Will be automatically loaded from contracts/deployments/localhost/AgreementEngine.json
# if not set. Only set this if you want to override the auto-detected address.
# AGREEMENT_ENGINE_ADDRESS=

# Verifier contract address (optional)
# Only needed if you want to register a verifier in the example script
# VERIFIER_ADDRESS=
