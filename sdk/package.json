{
  "name": "@shodai-network/agreements-protocol-evm",
  "version": "0.2.0",
  "description": "TypeScript SDK for the Agreements Protocol",
  "author": "CNS Labs",
  "license": "Apache-2.0",
  "main": "./dist/cjs/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build:inline-json": "node scripts/inline-json.mjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:module-markers": "node scripts/write-module-markers.mjs",
    "build": "npm run clean && npm run build:inline-json && npm run build:esm && npm run build:cjs && npm run build:module-markers",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "proof:p0:linea": "tsx scripts/prove-p0-linea.ts",
    "check:p0:linea": "tsx scripts/check-p0-linea-proof.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cns-labs",
    "agreements-protocol",
    "ethereum",
    "evm",
    "typescript"
  ],
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@types/jest": "^29.5.11",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20.10.6",
    "ethers": "^6.16.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "dotenv": "^16.3.1",
    "viem": "2.43.2"
  }
}
